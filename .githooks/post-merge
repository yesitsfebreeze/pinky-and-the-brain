#!/bin/sh
# pinky-memory: post-merge hook
# Fires after every successful `git pull` that merges new commits.
# Sets the reindex flag so the AI rebuilds index.md at the start of the next session,
# rather than blocking the current pull.

BRAIN_DIR="$(git rev-parse --show-toplevel)/.brain"

# Only flag if the .brain/ directory actually exists (skip on fresh clones before first sync)
if [ -d "$BRAIN_DIR" ]; then
  touch "$BRAIN_DIR/.needs-reindex"
fi
